# Example environment — SAFE, NON-LIVE DEFAULTS ONLY (AGENTS.md Appendix B.3).
# Copy to `.env` and fill real secrets there. NEVER commit real keys (B.17).

# --- Environment & mode -----------------------------------------------------
APP_ENV=local
# TRADING_MODE is never LIVE by default (Section 2.1).
TRADING_MODE=PAPER

# --- Identity / versioning (Section 4) -------------------------------------
EXCHANGE_ID=bybit
# live | testnet | demo  — three DIFFERENT Bybit environments (different endpoints + keys):
#   testnet = testnet.bybit.com (separate test network); demo = api-demo.bybit.com
#   (mainnet data + virtual-funds demo account, keys from the main site); live = real money.
# Use the value that matches where your EXCHANGE_API_KEY/SECRET were created.
EXCHANGE_ENV=testnet
EXCHANGE_ACCOUNT_TYPE=swap
BOT_INSTANCE_ID=QBOT_LOCAL
ORDER_CLIENT_ID_PREFIX=QBOT_LOCAL_v1_
CONFIG_VERSION=cfg_0001
UNIVERSE_VERSION=univ_0001
DATA_VERSION=data_0001
METADATA_VERSION=meta_0001
STRATEGY_VERSION=strat_0001
FEATURE_SET_VERSION=feat_0001
RISK_POLICY_VERSION=risk_0001
EXECUTION_POLICY_VERSION=exec_0001

# --- Infrastructure endpoints ----------------------------------------------
# Leave DATABASE_URL / REDIS_URL unset. The whole .env is loaded into the containers (compose
# `env_file`), but compose `environment` overrides these two to the service names
# (postgres/redis), so even if you set them here a container can't point at itself. Host tooling
# uses the localhost defaults in src/config/settings.py. Set them only for a real deployment.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/trading_bot
# REDIS_URL=redis://localhost:6379/0
OBJECT_STORAGE_URL=
# Local data lake / artifact paths (relative to repo root by default).

# --- Dashboard auth (mandatory outside local) ------------------------------
DASHBOARD_AUTH_MODE=basic
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-in-env

# --- Feature toggles (safe defaults; Appendix B.3) -------------------------
ENABLE_LIVE_TRADING=false
# These gate the scheduler's recurring jobs (research re-validation + paper run; ML shadow pass).
ENABLE_BACKGROUND_RESEARCH_JOBS=true
ENABLE_ML_SHADOW=false
ENABLE_ONLINE_LEARNING_SHADOW=false   # reserved (RL/learner run via gates, not scheduled jobs)
ENABLE_RL_SHADOW=false                # reserved

# --- Scheduler (recurring jobs; the `scheduler` service sets SCHEDULER_ENABLED=true) -------
SCHEDULER_ENABLED=false
SCHEDULER_TICK_SEC=60

# --- Exchange API credentials (LEAVE BLANK; real keys only in production) ---
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# --- Postgres (used by docker-compose postgres service) --------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trading_bot

# --- Monitoring / alert transports (optional) ------------------------------
# Each push channel activates only when its fields are set; otherwise alerts are log-only.
# Both are fail-safe (a delivery error never interrupts trading/jobs).
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_HOST=
ALERT_EMAIL_PORT=587
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=                 # comma-separated recipients
ALERT_EMAIL_USERNAME=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_USE_TLS=true
