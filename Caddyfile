# Caddy reverse proxy — the only externally published service (port 443).
# Local/dev: default site is `https://localhost`; Caddy serves it on :443 using
# its built-in internal CA (self-signed), so no public port 80 / ACME is needed.
# Production: set DASHBOARD_DOMAIN to a real hostname and Caddy provisions a
# public TLS certificate automatically — still on 443 only.

{$DASHBOARD_DOMAIN:https://localhost} {
	encode gzip
	# Dashboard shell + API are served by the backend service over the internal
	# network; the backend enforces dashboard auth (DASHBOARD_AUTH_MODE).
	reverse_proxy backend:8000
}
