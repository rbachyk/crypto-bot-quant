{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GateResult",
  "description": "Exact JSON the gate runner must print to stdout for `make -s run-gate GATE=<id> FORMAT=json`. The orchestrator parses this; field names are normative (use `id`, not `name`).",
  "type": "object",
  "required": ["gate_id", "overall", "criteria"],
  "additionalProperties": true,
  "properties": {
    "gate_id": { "type": "string", "description": "e.g. INFRA" },
    "overall": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "NOT_RUN"] },
    "report_path": { "type": "string" },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "description": "stable criterion id, e.g. INFRA-health" },
          "title": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "NOT_RUN"] },
          "measured": { "type": "object" },
          "threshold": { "type": "object" },
          "failure_reason": { "type": ["string", "null"] },
          "remediation_steps": { "type": "array", "items": { "type": "string" } },
          "rerun_job": { "type": "string" }
        }
      }
    }
  }
}
